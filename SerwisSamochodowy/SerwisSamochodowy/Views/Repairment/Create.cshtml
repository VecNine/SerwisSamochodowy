@model SerwisSamochodowy.Models.Repairment
@{ ViewData["Title"] = "Nowa Naprawa"; }

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-success text-white"><h3>Nowe zlecenie naprawy</h3></div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">Pojazd</label>
                        <select asp-for="IdVehicle" class="form-select" asp-items="ViewBag.Vehicles" required></select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">Mechanik</label>
                        <select asp-for="IdMechanic" class="form-select" asp-items="ViewBag.Mechanics" required></select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">Data</label>
                        <input asp-for="Date" type="datetime-local" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">Cena usługi (robocizna)</label>
                        <input asp-for="ServicePrice" type="number" step="0.01" class="form-control" required />
                    </div>
                </div>

                <hr />
                <h5>Wykorzystane części</h5>
                <div id="parts-container">
                    </div>
                <button type="button" class="btn btn-outline-primary btn-sm mb-3" onclick="addPartRow()">+ Dodaj część</button>

                <div class="mt-4 border-top pt-3">
                    <button type="submit" class="btn btn-success">Zapisz naprawę</button>
                    <a asp-action="Index" class="btn btn-secondary">Anuluj</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function addPartRow() {
            const container = document.getElementById('parts-container');
            const row = document.createElement('div');
            row.className = 'row mb-2 part-row';
            row.innerHTML = `
                <div class="col-md-7">
                    <select name="selectedParts" class="form-select">
                        <option value="0">-- Wybierz część --</option>
                        @foreach(var p in ViewBag.AllParts) {
                            <option value="@p.IdPart">@p.Name (@p.Cost zł)</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <input name="quantities" type="number" class="form-control" placeholder="Ilość" value="1" min="1" />
                </div>
                <div class="col-md-2">
                    <button type="button" class="btn btn-danger" onclick="this.parentElement.parentElement.remove()">X</button>
                </div>
            `;
            container.appendChild(row);
        }
    </script>
}