@model SerwisSamochodowy.Models.Users
@{
    ViewData["Title"] = "Dodaj Użytkownika";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h3 class="mb-0">Dodaj nowego użytkownika</h3>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="form-group mb-3">
                    <label class="fw-bold">Nazwa użytkownika (Login):</label>
                    <input name="username" class="form-control" placeholder="Wprowadź login" required />
                </div>

                <div class="form-group mb-3">
                    <label class="fw-bold">Hasło:</label>
                    <input name="password" type="password" class="form-control" placeholder="Wprowadź hasło" required />
                </div>

                <div class="form-check mb-4">
                    <input name="isAdmin" type="checkbox" value="true" class="form-check-input" id="adminCheck" />
                    <label class="form-check-label" for="adminCheck">
                        Uprawnienia Administratora
                    </label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4">Zapisz użytkownika</button>
                    <a asp-action="List" class="btn btn-outline-secondary">Anuluj i wróć</a>
                </div>
            </form>
        </div>
    </div>
</div>