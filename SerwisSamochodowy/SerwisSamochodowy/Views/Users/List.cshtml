@model IEnumerable<SerwisSamochodowy.Models.Users>
@{
    ViewData["Title"] = "Lista Użytkowników";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Zarządzanie Użytkownikami</h2>
    <a asp-action="Create" class="btn btn-success">Dodaj nowego użytkownika</a>
</div>

<table class="table table-striped border shadow-sm">
    <thead class="table-dark">
    <tr>
        <th>ID</th>
        <th>Login</th>
        <th>Rola</th>
        <th>Token API</th>
        <th>Akcje</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.IdUser</td>
            <td>@item.Username</td>
            <td>
                <span class="badge @(item.IsAdmin ? "bg-danger" : "bg-info")">
                    @(item.IsAdmin ? "Administrator" : "Użytkownik")
                </span>
            </td>
            <td><code>@item.ApiToken</code></td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.IdUser" class="btn btn-sm btn-primary">Edytuj</a>
                <a asp-action="Delete" asp-route-id="@item.IdUser" class="btn btn-sm btn-danger">Usuń</a>
            </td>
        </tr>
    }
    </tbody>
</table>