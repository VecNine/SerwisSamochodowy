@model SerwisSamochodowy.Models.Parts
@{ ViewData["Title"] = "Edytuj Część"; }

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Edytuj część: @Model.Name</h3>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="IdPart" />

                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label fw-bold">Nazwa części</label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Cost" class="control-label fw-bold">Koszt (PLN)</label>
                    <input asp-for="Cost" type="number" step="0.01" class="form-control" required />
                    <span asp-validation-for="Cost" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary px-4">Zapisz zmiany</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Anuluj</a>
            </form>
        </div>
    </div>
</div>