@model IEnumerable<SerwisSamochodowy.Models.Parts>

@{
    ViewData["Title"] = "Lista Części";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Zarządzanie Częściami</h2>
        <a asp-action="Create" class="btn btn-success fw-bold">Dodaj nową część</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nazwa części</th>
                        <th>Koszt (PLN)</th>
                        <th class="text-end">Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.IdPart</td>
                                <td>@item.Name</td>
                                <td>@item.Cost.ToString("C")</td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.IdPart" class="btn btn-sm btn-primary">Edytuj</a>
                                    
                                    <a asp-action="Delete" asp-route-id="@item.IdPart" class="btn btn-sm btn-outline-danger">Usuń</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted">
                                Brak części w bazie. Dodaj pierwszą część!
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>