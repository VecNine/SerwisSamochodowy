@model SerwisSamochodowy.Models.Mechanic
@{ ViewData["Title"] = "Nowy Mechanik"; }

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-success text-white"><h3 class="mb-0">Dodaj mechanika</h3></div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold">Imię</label>
                    <input asp-for="Name" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label asp-for="Surname" class="form-label fw-bold">Nazwisko</label>
                    <input asp-for="Surname" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label asp-for="Salary" class="form-label fw-bold">Pensja (PLN)</label>
                    <input asp-for="Salary" type="number" step="0.01" class="form-control" required />
                </div>
                <div class="mb-4">
                    <label asp-for="EmploymentStartDate" class="form-label fw-bold">Data rozpoczęcia pracy</label>
                    <input asp-for="EmploymentStartDate" type="date" class="form-control" required />
                    <span asp-validation-for="EmploymentStartDate" class="text-danger"></span>
                </div>
                
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4">Zapisz</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Anuluj</a>
                </div>
            </form>
        </div>
    </div>
</div>