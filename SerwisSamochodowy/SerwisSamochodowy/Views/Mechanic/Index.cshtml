@using Microsoft.AspNetCore.Http
@model IEnumerable<SerwisSamochodowy.Models.Mechanic>

@{ 
    ViewData["Title"] = "Lista Mechaników";
    bool isAdmin = Context.Session.GetString("IsAdmin") == "True";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Mechanicy</h2>
        @if (isAdmin) {
            <a asp-action="Create" class="btn btn-success fw-bold">Dodaj mechanika</a>
        }
    </div>
    
    <div class="card shadow-sm">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Imię</th>
                <th>Nazwisko</th>
                <th>Pensja</th>
                <th>Zatrudniony od</th>
                @if (isAdmin) { <th class="text-end">Akcje</th> }
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td>@item.IdMechanic</td>
                    <td>@item.Name</td>
                    <td>@item.Surname</td>
                    <td>@item.Salary.ToString("C")</td>
                    <td>@item.EmploymentStartDate.ToString("MM/yyyy")</td>
                    @if (isAdmin) {
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.IdMechanic" class="btn btn-sm btn-primary">Edytuj</a>
                            <a asp-action="Delete" asp-route-id="@item.IdMechanic" class="btn btn-sm btn-outline-danger">Usuń</a>
                        </td>
                    }
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>